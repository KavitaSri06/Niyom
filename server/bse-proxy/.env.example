# NIYOM BSE Proxy — environment template. Copy to .env on the droplet and fill.
# NEVER commit the real .env.

# demo | prod  (demo = https://starmfv2demo.bseindia.com/api)
BSE_ENV=demo
# Optional override; normally derived from BSE_ENV
# BSE_BASE_URL=

# BSE StAR MF 2.0 API credentials (from BSE onboarding — sandbox first)
BSE_USERNAME=
BSE_PASSWORD=
BSE_MEMBER_CODE=

# Port the proxy listens on (nginx proxies 443 → this)
PORT=8080

# Comma-separated browser origins allowed to call this proxy
ALLOWED_ORIGINS=https://www.niyomwealth.com,https://niyomwealth.com,http://localhost:5173

# Supabase (used ONLY to verify the caller's session JWT)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Set to false only for local smoke tests without a Supabase session
REQUIRE_AUTH=true
