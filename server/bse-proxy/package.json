{
  "name": "niyom-bse-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "NIYOM server-side proxy to BSE StAR MF 2.0 (v2 REST). Holds BSE credentials; runs on the whitelisted-IP VPS.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsc -p tsconfig.json --watch & node --watch dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.3"
  }
}
